# Public Discord invite / OAuth URL the "Add to Discord" CTA points to.
# Copy to .env.local and fill in when ready. Defaults to "#" if unset.
NEXT_PUBLIC_INVITE_URL=

# Discord OAuth2 — required for the /callback verification flow.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
OAUTH_REDIRECT_URI=https://cvrse.lol/callback

# PostgreSQL — shared with the bot (same database).
DATABASE_URL=
